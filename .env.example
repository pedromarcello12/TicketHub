# Copie este arquivo para ".env" e preencha com valores reais antes de rodar docker compose.
# O ".env" nunca deve ser commitado (ja esta no .gitignore).

# Chave de assinatura JWT compartilhada entre Auth.Api e os servicos que validam o token.
# Gere uma chave forte, por exemplo: openssl rand -base64 48
JWT_SECRET_KEY=troque-esta-chave-por-um-valor-secreto-com-pelo-menos-32-caracteres
